# Copie para .env e ajuste conforme necessário.

# --- Proxy ---
# Proxy único (compat). Ex.: http://usuario:senha@host:porta
ONESAVER_PROXY=
# Lista de proxies para rotação (vírgula). Tem prioridade sobre ONESAVER_PROXY.
ONESAVER_PROXIES=

# --- Cookies (conta-robô) ---
# Arquivo único de cookies (Netscape). Dentro do container: /secrets/cookies.txt
ONESAVER_COOKIES_FILE=/secrets/cookies.txt
# Diretório com vários cookies *.txt para o pool. Dentro do container: /secrets/cookies
ONESAVER_COOKIES_DIR=/secrets/cookies
# Segundos que um cookie fica em cooldown após falhar (padrão 600 = 10min).
ONESAVER_COOKIE_COOLDOWN=600

# --- Cache ---
ONESAVER_CACHE_TTL=21600
ONESAVER_CACHE_MAX_ENTRIES=5000

# --- Segurança / limites ---
# Se definido, exige header "X-API-Key: <valor>" no /resolve.
ONESAVER_API_KEY=
ONESAVER_RATE_LIMIT=30/minute
ONESAVER_CORS_ORIGINS=*
